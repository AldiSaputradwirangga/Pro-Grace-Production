---
    import { Image } from "astro:assets";
    import heroImage from '../assets/index image/hero.jpg'
---

<section class="relative h-screen w-full overflow-hidden">
   <figure>
        <Image src={heroImage} alt="Luruh Still" decoding="sync" loading="eager" class="absolute inset-0 w-full h-full object-cover object-[70%_center]"/>
       <div class="absolute top-1/2 px-6 flex flex-col gap-1 md:right-1/2 md:left-10 -translate-y-1/2">
           <span class="font-serif text-[12px] md:text-[16px]">WELCOME TO PRO GRACE PRODUCTION</span>
           <h1 class="font-serif font-bold text-4xl md:text-5xl">A Story That Echo Beyond the Screen</h1>
           <p class="font-display tracking-wide md:text-[16px]">Through our work, we aim to capture the quiet emotions, fragile memories, and human connection that stay after the story ends.</p>  
       </div>
   </figure>
</section>